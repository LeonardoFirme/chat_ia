# frontend/.gitignore

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/
/build

# Environment Files (CRÍTICO: Proteção total de segredos)
.env
.env.local
.env.production
.env.development
.env*.local
.env.backup
.env.sample

# Prisma (Gerado em tempo de execução)
/src/generated/prisma
/prisma/db.sqlite
/prisma/db.sqlite-journal

# Testing
/coverage

# Misc
.DS_Store
*.pem
*.key
Thumbs.db

# Debug Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel & Turbo
.vercel
.turbo

# TypeScript
*.tsbuildinfo
# next-env.d.ts (Opcional manter no git, mas recomendado ignorar se usar proxy.ts customizado)

# Python Backend (Caso o .gitignore seja na raiz do monorepo)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
backend/requirements.txt.bak